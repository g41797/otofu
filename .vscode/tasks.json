{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Odin",
            "type": "shell",
            "command": "odin",
            "args": [
                "build",
                "${workspaceFolder}",
                "-debug",
                "-o:none",
                "-out:${workspaceFolder}/${workspaceFolderBasename}",
                "-collection:matryoshka=deps/matryoshka"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build Library",
            "type": "shell",
            "command": "odin",
            "args": [
                "build",
                "${workspaceFolder}/${input:buildPackage}",
                "-build-mode:lib",
                "-debug",
                "-o:none",
                "-collection:matryoshka=deps/matryoshka"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "odin",
            "args": [
                "build",
                "${workspaceFolder}/${input:testPackage}",
                "-build-mode:test",
                "-debug",
                "-o:none",
                "-out:${workspaceFolder}/debug_current",
                "-collection:matryoshka=deps/matryoshka"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "odin",
            "args": [
                "test",
                "${workspaceFolder}/${input:testPackage}",
                "-vet",
                "-strict-style",
                "-disallow-do",
                "-o:none",
                "-debug",
                "-collection:matryoshka=deps/matryoshka"
            ],
            "group": "test",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "buildPackage",
            "type": "pickString",
            "description": "Select package to build as library",
            "options": [
                {
                    "label": "pipeline/",
                    "value": "pipeline"
                },
            ]
        },
        {
            "id": "testPackage",
            "type": "pickString",
            "description": "Select test package",
            "options": [
                {
                    "label": "tests/unit/pipeline/",
                    "value": "tests/unit/pipeline"
                },
            ]
        }
    ]
}
